# Copy this file to .env and fill in real values. .env is gitignored.

# Financial Modeling Prep - https://site.financialmodelingprep.com
FMP_API_KEY=your_fmp_api_key_here

# Alpaca - https://app.alpaca.markets (generate paper keys from the Paper account view)
ALPACA_API_KEY=your_alpaca_key_id_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# true = paper trading endpoint (default). false = real-money endpoint.
ALPACA_PAPER=true

# Extra safety gate for real money. While ALPACA_PAPER=false, orders are refused
# unless this is also true AND the typed LIVE acknowledgment is given in the UI.
LIVE_TRADING_ENABLED=false

# Tradier - generate a token at dashboard.tradier.com (Settings -> API Access).
# TRADIER_ENV=sandbox uses the paper environment (needs a sandbox token,
# delayed data); production is REAL MONEY and gets the full live gating.
TRADIER_ACCESS_TOKEN=your_tradier_token_here
TRADIER_ENV=production
# Optional - auto-discovered from your profile if blank.
TRADIER_ACCOUNT_ID=

# Public.com - generate the secret at public.com Settings -> Security -> API.
# WARNING: Public has NO paper environment. BROKER=public means REAL MONEY on
# every order, and the platform enforces the live gates (LIVE_TRADING_ENABLED
# plus typed LIVE in the UI) for all Public orders.
PUBLIC_API_SECRET=your_public_api_secret_here

# Which brokerage executes orders and provides account/positions:
#   alpaca (default, supports paper) | tradier | public (REAL MONEY ONLY)
BROKER=alpaca

# Which provider feeds the scanner (chains, greeks, spot):
#   alpaca (default) | tradier | public
DATA_SOURCE=alpaca

# Set this whenever you bind beyond localhost (HOST=0.0.0.0), e.g. to open
# the dashboard from your phone on the same Wi-Fi. Every request must then
# carry it: first load via /?key=..., the page remembers it afterwards.
DASHBOARD_TOKEN=

# Optional overrides (defaults shown)
# HOST=127.0.0.1
# PUBLIC_ACCOUNT_ID=
# ALPACA_DATA_FEED=iex
# ALPACA_OPTIONS_FEED=indicative
# FMP_BASE_URL=https://financialmodelingprep.com
# PORT=8787
# DB_PATH=options_platform.db
